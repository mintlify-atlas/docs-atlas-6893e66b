  "publicApiSurface": [
    "igcmd quick_setup - Quick setup wizard for first-time users",
    "igcmd set_wallpaper <path> <style> - Set desktop wallpaper",
    "igcmd set_default_photo_viewer [exts] - Register as default photo viewer",
    "igcmd remove_default_photo_viewer [exts] - Unregister as default photo viewer",
    "igcmd start_slideshow <path> - Start slideshow from file",
    "igcmd export_frames <path> - Export frames from animated images",
    "igcmd check_for_update - Check for application updates",
    "igcmd install_languages <paths> - Install language packs",
    "igcmd install_themes <paths> - Install theme packs",
    "igcmd uninstall_theme <path> - Uninstall theme pack",
    "igcmd set_lock_screen <path> - Set Windows lock screen background",
    "igcmd lossless_compress <path> - Lossless image compression",
    "igcmd set_startup_boost - Enable startup optimization",
    "igcmd remove_startup_boost - Disable startup optimization"
